---
import { WebsiteAssets } from './LandingPage.astro';
import MainCard from './MainCard.astro';
import SocialIcon from './SocialIcon.astro';
import ButtonMainPage from './ButtonMainPage.astro';
import Short_Logo from '~/assets/images/Short_Logo.svg';
import SubscribeForm from './SubscribeForm.astro';

export interface Props {
	websiteAssets: WebsiteAssets;
	id: string;
}
const { websiteAssets, id } = Astro.props;
---

<div class="w-full m-auto overflow-x-hidden relative">
	<div
		class="md:border-l-1 md:border-white middle hidden !md:block md:dark:block absolute animate-wigglemiddle left-[50%] h-full min-h-full cursor-ew-resize z-20">
		<div
			class="fixed transform -translate-x-2/4 w-10 h-10 border-1 bg-white border-orange top-11/36 grid grid-cols-[1fr_1fr] rounded-1/2 items-center z-30">
			<img
				src={Short_Logo}
				height={311}
				width={667}
				alt="RunTime Machines slider icon"
				class="ml-1/2 pointer-events-none"
			/>
		</div>
	</div>
	<div class="grid grid-rows-[auto_auto] md:grid-rows-[auto_auto]">
		<div class="grid">
			<div class="m-auto pt-12 pb-5 sm:w-sm w-xs">
				<img src={websiteAssets.homepage.main_logo} height={302} width={806} alt={websiteAssets.homepage.main_desc} />
			</div>
		</div>
		<div class="flex md:hidden">
			<div
				class="block md:hidden flex sm:w-sm w-xs m-auto px-3 grid grid-cols-[auto_auto_auto] font-semibold text-white">
				<span class="m-auto text-xl">Night</span>
				<button
					class="toggleTheme m-auto w-20 h-10 rounded-full bg-white flex items-center transition duration-300 focus:outline-none shadow">
					<div
						class="toggleThemeSwitch w-12 h-12 relative rounded-full transition duration-500 transform bg-yellow-500 -translate-x-2 p-1 text-white">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
							></path>
						</svg>
					</div>
				</button>
				<span class="m-auto text-xl">Day</span>
			</div>
		</div>
		<div class="grid max-w-4xl m-auto pt-5">
			<div
				class="ml-auto mr-auto mb-auto grid md:grid-cols-[1fr_1fr] grid-cols-[1fr] grid-rows-[1fr_auto] gap-x-2 lg:gap-x-10 pb-10 font-badaboom">
				<MainCard
					image={websiteAssets.homepage.left_section}
					text="We think"
					css_classes={[]}
					desc={websiteAssets.homepage.left_desc}
				/>
				<MainCard
					image={websiteAssets.homepage.right_section}
					text="We build"
					css_classes={['<md:dark:row-start-1 <md:row-start-2']}
					desc={websiteAssets.homepage.right_desc}
				/>
				<div class="md:row-start-2 md:col-start-1 md:col-end-2 md:pb-0 pb-10">
					<ButtonMainPage text={'Sharpen your skills'} idButton={'think'} />
				</div>
				<div class="md:row-start-2 md:col-start-2 md:col-end-3">
					<ButtonMainPage text={'Play RTM Runner'} idButton={'play'} />
				</div>
			</div>
			<SubscribeForm id={id} prefix="main" />
		</div>
		<div class="flex pb-5">
			<div class="w-30 flex m-auto">
				<SocialIcon
					image={websiteAssets.homepage.linkedin_image}
					link="https://www.linkedin.com/company/91547632/"
					desc={websiteAssets.homepage.linkedin_desc}
				/>
				<SocialIcon
					image={websiteAssets.homepage.gh_image}
					link="https://github.com/runtime-machines"
					desc={websiteAssets.homepage.gh_desc}
				/>
			</div>
		</div>
	</div>
</div>

<script>
	const switchToggle = document.getElementsByClassName('toggleThemeSwitch');
	let isDay = false;

	const lightIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
	<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
	</svg>`;

	const darkIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
	<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
	</svg>`;

	const toggle_buttons = document.getElementsByClassName('toggleTheme');
	for (let e = 0; e < toggle_buttons.length; e++) {
		const button = toggle_buttons[e];
		button.addEventListener('click', toggleTheme);
	}

	function toggleTheme() {
		isDay = !isDay;
		localStorage.setItem('isDay', String(isDay));
		switchTheme();
	}

	function switchTheme() {
		//console.log(isDay);
		if (isDay) {
			for (let e = 0; e < switchToggle.length; e++) {
				const element = switchToggle[e];
				element.classList.remove('bg-gray-dark', '-translate-x-2');
				element.classList.add('bg-yellow-500', 'translate-x-full');
			}
			setTimeout(() => {
				for (let e = 0; e < switchToggle.length; e++) {
					switchToggle[e].innerHTML = darkIcon;
				}
			}, 0);
			document.getElementById('left')?.classList.add('<md:max-h-0');
			document.getElementById('right')?.classList.remove('<md:max-h-0');
		} else {
			for (let e = 0; e < switchToggle.length; e++) {
				const element = switchToggle[e];
				element.classList.add('bg-gray-dark', '-translate-x-2');
				element.classList.remove('bg-yellow-500', 'translate-x-full');
			}
			setTimeout(() => {
				for (let e = 0; e < switchToggle.length; e++) {
					switchToggle[e].innerHTML = lightIcon;
				}
			}, 0);
			document.getElementById('right')?.classList.add('<md:max-h-0');
			document.getElementById('left')?.classList.remove('<md:max-h-0');
		}
	}

	switchTheme();
</script>
